{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run PinShot",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/PinShot/PinShot.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish PinShot",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "src/PinShot/PinShot.csproj",
        "-c",
        "Release",
        "-r",
        "win-x64",
        "--self-contained",
        "false"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
